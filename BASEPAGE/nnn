class Checkout(View):
    def get(self,request):
        form_instance = OrderForm()
        context = {'form':form_instance}
        return render(request,'checkout.html',context)
    def post(self, request):
        form_instance = OrderForm(request.POST)

        if form_instance.is_valid():
            u = form_instance.save(commit=False)
            user = request.user
            u.user = user

            cart_items = Cart.objects.filter(user=user)

            total = 0
            for i in cart_items:
                total += (i.quantity * i.product.price)

            u.amount = total
            u.save()

            if u.payment_method == "online":
                client = razorpay.Client(
                    auth=('rzp_test_SeVVMTZl4xua5M', 'U00WJeQa6lQGuWKEuDT4zyPL')
                )

                response_payment = client.order.create({
                    'amount': int(u.amount * 100),
                    'currency': 'INR',
                    'payment_capture': 1
                })

                order_id = response_payment['id']
                u.order_id = order_id
                u.save()

                context = {'payment': response_payment}
                return render(request, 'payment.html', context)

            else:
                 pass

        # ✅ ALSO handle invalid form
        return render(request, 'checkout.html', {'form': form_instance})







